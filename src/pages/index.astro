---
import '../styles/global.css';

const metodologi = [
  { step: 'PERSIAPAN PROGRAM', text: 'Koordinasi dengan pihak institusi untuk menentukan tujuan kegiatan, jumlah peserta, serta kebutuhan khusus yang ingin dicapai.' },
  { step: 'PELAKSANAAN ASESMEN', text: 'Proses pengumpulan data dilakukan sesuai prosedur layanan dengan pendampingan dari tim profesional.' },
  { step: 'PENGOLAHAN & ANALISIS', text: 'Data yang diperoleh dianalisis menggunakan pendekatan terukur untuk menghasilkan gambaran potensi dan karakter individu.' },
  { step: 'PENYAMPAIAN HASIL & REKOMENDASI', text: 'Hasil pemetaan disajikan dalam bentuk laporan yang informatif serta dilengkapi arahan pengembangan yang dapat diterapkan oleh institusi' }
];

const programContoh = [
  'Asesmen dan pemetaan potensi serta karakter peserta didik',
  'Program pengembangan gaya belajar',
  'Workshop perencanaan karir dan masa depan',
  'Pelatihan peningkatan kualitas Sumber Daya Manusia',
  'Seminar motivasi dan penguatan karakter',
  'Pendampingan strategi pembinaan individu'
];
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Potensia Mitra Insani</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta property="og:image" content="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[var(--color-background)] text-[var(--color-text)] overflow-x-hidden antialiased">
    
    <!-- Floating Navigation -->
    <nav class="fixed bottom-6 md:bottom-auto md:top-8 left-1/2 -translate-x-1/2 z-50 bg-white/90 backdrop-blur-md px-4 md:px-8 py-3 rounded-full shadow-[0_10px_30px_rgba(30,58,31,0.2)] border border-white/40 animate-[var(--animate-anti-gravity-slow)] flex items-center justify-between gap-2 md:gap-6 w-[95%] md:w-auto max-w-4xl overflow-x-auto">
      <a href="#beranda" class="nav-link px-4 py-2 rounded-full text-sm md:text-base font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-secondary)]/10 transition-all duration-300 whitespace-nowrap">Home</a>
      <a href="#metodologi" class="nav-link px-4 py-2 rounded-full text-sm md:text-base font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-secondary)]/10 transition-all duration-300 whitespace-nowrap">Method</a>
      <a href="#portofolio" class="nav-link px-4 py-2 rounded-full text-sm md:text-base font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-secondary)]/10 transition-all duration-300 whitespace-nowrap">Portfolio</a>
      <a href="#komitmen" class="nav-link px-4 py-2 rounded-full text-sm md:text-base font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-secondary)]/10 transition-all duration-300 whitespace-nowrap">Mission</a>
      <a href="#tim" class="nav-link px-4 py-2 rounded-full text-sm md:text-base font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-secondary)]/10 transition-all duration-300 whitespace-nowrap">Team</a>
      <a href="#kontak" class="nav-link px-4 py-2 rounded-full text-sm md:text-base font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-secondary)]/10 transition-all duration-300 whitespace-nowrap">Contact</a>
    </nav>

    <!-- Hero & Logo Area -->
    <section id="beranda" class="relative min-h-screen flex flex-col items-center justify-center p-8 overflow-hidden z-10 pt-24">
      <!-- Abstract Background Elements -->
      <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-gradient-to-br from-[var(--color-secondary)] to-transparent opacity-10 blur-3xl animate-[var(--animate-anti-gravity-slow)] -z-10"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[40vw] h-[40vw] rounded-full bg-gradient-to-tl from-[var(--color-primary)] to-transparent opacity-10 blur-3xl animate-[var(--animate-anti-gravity-reverse)] -z-10"></div>

      <!-- Animated Logo Container -->
      <div class="reveal opacity-0 translate-y-10 transition-all duration-1000 ease-out mb-12 mt-16 md:mt-0 animate-[var(--animate-anti-gravity)] z-20">
        <div class="relative w-64 h-64 md:w-80 md:h-80 flex items-center justify-center bg-transparent rounded-full hover:scale-105 transition-transform duration-500">
          <img src="/logo-removebg.png" alt="Logo PT Potensia Mitra Insani" class="w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(30,58,31,0.4)]" />
        </div>
      </div>

      <div class="reveal opacity-0 translate-y-10 transition-all duration-1000 delay-200 ease-out text-center max-w-5xl">
        <h1 class="text-7xl md:text-9xl font-bold uppercase tracking-tight text-[var(--color-primary)] mb-8 drop-shadow-sm">
          Potensia Mitra Insani
        </h1>
        <p class="text-2xl md:text-3xl text-[var(--color-text-muted)] max-w-3xl mx-auto font-medium leading-relaxed">
          Menggali potensi, membangun masa depan dengan pendekatan terukur, aplikatif, dan berkelanjutan.
        </p>
      </div>
    </section>

    <!-- METODA PELAKSANAAN -->
    <section id="metodologi" class="relative py-24 px-8 bg-white overflow-hidden">
      <!-- Diagonal Split Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#f0f4f0] to-transparent w-[120%] h-[120%] -rotate-6 origin-top-left -z-10"></div>
      
      <div class="max-w-7xl mx-auto">
        <div class="reveal opacity-0 translate-y-10 transition-all duration-1000 ease-out text-center mb-20">
          <h2 class="text-5xl md:text-7xl font-bold text-[var(--color-primary)] uppercase tracking-wider mb-8 relative inline-block">
            Metoda Pelaksanaan
            <!-- Floating accent -->
            <div class="absolute -top-6 -right-12 w-16 h-8 bg-[var(--color-secondary)] rounded-full opacity-20 blur-xl animate-[var(--animate-anti-gravity-fast)]"></div>
          </h2>
          <p class="text-2xl text-[var(--color-text-muted)] max-w-4xl mx-auto leading-relaxed">
            Pelaksanaan program dilakukan melalui tahapan yang sistematis dan terstruktur guna memastikan setiap individu memperoleh hasil pemetaan yang akurat serta mudah dipahami.
          </p>
        </div>

        <h3 class="reveal opacity-0 translate-x-10 transition-all duration-1000 ease-out text-3xl font-bold text-[var(--color-primary)] mb-12 uppercase">Tahapan Kegiatan Meliputi</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
          {metodologi.map((item, index) => (
            <div class={`reveal opacity-0 translate-y-10 transition-all duration-1000 ease-out flex flex-col group`} style={`transition-delay: ${index * 150}ms`}>
              <div class="bg-gradient-to-r from-[#8bb95b] to-[#458032] text-white py-4 px-6 rounded-full shadow-lg mb-6 transform group-hover:-translate-y-2 group-hover:shadow-[0_10px_20px_rgba(82,140,61,0.3)] transition-all duration-300">
                <h4 class="font-bold text-center uppercase tracking-wide text-base">{item.step}</h4>
              </div>
              <p class="text-[var(--color-text-muted)] text-lg leading-relaxed px-4">
                {item.text}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PORTOFOLIO KEGIATAN -->
    <section id="portofolio" class="relative py-24 px-8 bg-[var(--color-background)]">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
        <div class="lg:w-1/2 reveal opacity-0 -translate-x-10 transition-all duration-1000 ease-out">
          <h2 class="text-5xl md:text-7xl font-bold text-[var(--color-primary)] uppercase tracking-wider mb-8">
            Portofolio Kegiatan
          </h2>
          <p class="text-[var(--color-text-muted)] mb-6 text-2xl leading-relaxed">
            PT. Potensia Mitra Insani memiliki pengalaman penyelenggaraan berbagai program pengembangan individu dan peningkatan kualitas Sumber Daya Manusia melalui kegiatan edukatif, pelatihan dan pendampingan.
          </p>
          <p class="text-[var(--color-text-muted)] mb-12 text-2xl leading-relaxed">
            Program yang kami hadirkan dirancang agar relevan dengan kebutuhan peserta serta memberikan hasil yang dapat langsung diterapkan dalam lingkungan pendidikan maupun organisasi.
          </p>

          <h3 class="text-3xl font-bold text-[var(--color-primary)] mb-6 uppercase tracking-wide">Contoh Program Yang Dapat Dilaksanakan</h3>
          <ul class="space-y-5">
            {programContoh.map((prog, index) => (
              <li class={`reveal opacity-0 translate-x-10 transition-all duration-700 ease-out flex items-start group`} style={`transition-delay: ${index * 100}ms`}>
                <!-- Star/Polygon Icon -->
                <svg class="w-8 h-8 text-[var(--color-secondary)] mr-4 mt-1 flex-shrink-0 animate-[var(--animate-anti-gravity-slow)]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
                </svg>
                <span class="text-xl md:text-2xl text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">{prog}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <!-- Collage / Floating Images -->
        <div class="lg:w-1/2 relative h-[600px] w-full reveal opacity-0 translate-x-10 transition-all duration-1000 ease-out">
          <!-- Main Photo Placeholder -->
          <div class="absolute top-10 right-10 w-2/3 h-2/3 rounded-xl overflow-hidden shadow-2xl animate-[var(--animate-anti-gravity)] z-20 border-4 border-white">
            <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=800" alt="Pelatihan" class="w-full h-full object-cover" />
          </div>
          <!-- Secondary Photo Placeholder -->
          <div class="absolute bottom-10 left-10 w-3/5 h-2/5 rounded-xl overflow-hidden shadow-xl animate-[var(--animate-anti-gravity-reverse)] z-30 border-4 border-white">
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80&w=800" alt="Diskusi" class="w-full h-full object-cover" />
          </div>
          <!-- Background decorative circle -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[var(--color-secondary)] opacity-10 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </section>

    <!-- KOMITMEN KERJASAMA -->
    <section id="komitmen" class="relative py-32 px-8 bg-white overflow-hidden">
      <!-- Diagonal intersecting background -->
      <div class="absolute top-0 right-0 w-full h-full bg-[#f4f6f4] -skew-y-3 origin-top-right -z-10"></div>
      
      <div class="max-w-5xl mx-auto text-center reveal opacity-0 scale-95 transition-all duration-1000 ease-out">
        <h2 class="text-5xl md:text-7xl font-bold text-[var(--color-primary)] uppercase tracking-wider mb-12">
          Komitmen Kerjasama
        </h2>
        <div class="space-y-8 text-2xl md:text-3xl text-[var(--color-text)] mb-16 leading-relaxed">
          <p>Kami percaya bahwa setiap individu memiliki potensi unik yang dapat berkembang secara optimal apabila dikenali dan diarahkan dengan tepat.</p>
          <p>PT Potensia Mitra Insani siap menjadi mitra strategis bagi institusi dalam menghadirkan program pengembangan yang terukur, aplikatif dan berkelanjutan.</p>
          <p>Kami membuka peluang kerjasama dengan berbagai pihak demi terciptanya peningkatan kualitas Sumber Daya Manusia yang lebih baik.</p>
        </div>
        
        <!-- Plants Image / Growth metaphor with Anti-gravity floating wrapper -->
        <div class="w-full h-[400px] rounded-3xl overflow-hidden shadow-[0_30px_60px_-15px_rgba(30,58,31,0.3)] animate-[var(--animate-anti-gravity-slow)] relative group">
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent z-10"></div>
          <img src="https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&q=80&w=1200" alt="Pertumbuhan Tunas" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
        </div>
      </div>
    </section>

    <!-- TIM KAMI -->
    <section id="tim" class="relative py-32 px-8 bg-[var(--color-background)] overflow-hidden">
      <!-- Fingerprint Abstract Graphic -->
      <div class="absolute bottom-[5%] left-[-15%] w-[600px] h-[600px] text-[var(--color-secondary)] opacity-10 -z-10 animate-[var(--animate-anti-gravity-reverse)] pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.3" stroke="currentColor" class="w-full h-full drop-shadow-xl">
          <!-- Multi-layered fingerprint to simulate density -->
          <g transform="scale(1) translate(0, 0)">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
          </g>
          <g transform="scale(0.8) translate(3, 3)">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
          </g>
          <g transform="scale(1.2) translate(-2, -2)">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
          </g>
          <g transform="scale(1.4) translate(-3.5, -3.5)">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
          </g>
        </svg>
      </div>

      <div class="max-w-7xl mx-auto flex flex-col-reverse lg:flex-row gap-16 items-center">
        <div class="lg:w-1/2 reveal opacity-0 -translate-x-10 transition-all duration-1000 ease-out">
          <h2 class="text-5xl md:text-7xl font-bold text-[var(--color-primary)] uppercase tracking-wider mb-8">
            Tim Kami
          </h2>
          <p class="text-[var(--color-text-muted)] mb-6 text-2xl leading-relaxed">
            PT. Potensia Mitra Insani didukung oleh tim yang memiliki pengalaman dalam bidang pengembangan Sumber Daya Manusia, pelatihan dan pendampingan individu maupun organisasi.
          </p>
          <p class="text-[var(--color-text-muted)] text-2xl leading-relaxed">
            Setiap konsultan bekerja dengan menjunjung tinggi profesionalitas, objektifitas, serta komitmen untuk memberikan pelayanan terbaik sesuai kebutuhan mitra kerja.
          </p>
        </div>
        
        <div class="lg:w-1/2 relative flex justify-end reveal opacity-0 translate-x-10 transition-all duration-1000 ease-out">
          <!-- Circular masked image setup -->
          <div class="relative w-[500px] h-[500px]">
            <!-- Outer overlapping hands -->
            <div class="absolute inset-0 rounded-full overflow-hidden border-8 border-white shadow-2xl z-10 animate-[var(--animate-anti-gravity-fast)]">
               <img src="https://images.unsplash.com/photo-1528605248644-14dd04022da1?auto=format&fit=crop&q=80&w=800" alt="Tim Bersama" class="w-full h-full object-cover" />
            </div>
            <!-- Inner drone/agriculture overlay -->
            <div class="absolute -left-10 top-1/4 w-[300px] h-[300px] rounded-full overflow-hidden border-8 border-[var(--color-primary)] shadow-xl z-20 animate-[var(--animate-anti-gravity)]">
               <img src="https://images.unsplash.com/photo-1586771107445-d3afaf0dd868?auto=format&fit=crop&q=80&w=600" alt="Drone Pertanian" class="w-full h-full object-cover" />
            </div>
            <!-- Large green circle accent -->
            <div class="absolute -right-8 -bottom-8 w-full h-full rounded-full border-[16px] border-[var(--color-secondary)] opacity-50 z-0 animate-[spin_30s_linear_infinite]"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- THANK YOU / CTA -->
    <section id="kontak" class="relative min-h-[80vh] flex items-center justify-center py-24 px-8 text-white overflow-hidden text-center z-10">
      <!-- Rainbow/Nature Background -->
      <div class="absolute inset-0 -z-20">
        <img src="https://images.unsplash.com/photo-1498036882173-b41c28af5cb9?auto=format&fit=crop&q=80&w=1600" alt="Rainbow landscape" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/30 backdrop-blur-[2px]"></div>
      </div>
      
      <div class="reveal opacity-0 translate-y-10 transition-all duration-1000 ease-out max-w-2xl bg-black/20 p-12 rounded-3xl backdrop-blur-md border border-white/10 shadow-[0_0_50px_rgba(255,255,255,0.1)]">
        <h2 class="text-7xl md:text-9xl font-bold uppercase tracking-widest mb-12 drop-shadow-[0_5px_15px_rgba(0,0,0,0.5)] animate-[var(--animate-anti-gravity)]">
          Thank You.
        </h2>
        
        <div class="space-y-3 text-xl md:text-2xl drop-shadow-md tracking-wide">
          <p class="font-bold text-2xl md:text-3xl mb-6">KONTAK</p>
          <p class="font-semibold text-3xl mb-2">PT POTENSIA MITRA INSANI</p>
          <p>Jl. Cendrawasih Komp. Diknas P&K</p>
          <p>Blok.A no.5 Rt.005 Rw.006</p>
          <p>Cipayung - Ciputat</p>
          <p>Tangerang Selatan</p>
          <p class="mt-6 text-[var(--color-secondary)] font-bold text-3xl drop-shadow-[0_0_15px_rgba(255,255,255,0.8)] hover:scale-105 transition-transform inline-block">~ 0817.987.0512 ~</p>
          <p class="text-2xl">potensiamitrainsani@gmail.com</p>
        </div>
      </div>
    </section>

    <!-- Interactive Anti-Gravity Logic & Reveal Animation -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Scroll Reveal Logic
        const reveals = document.querySelectorAll('.reveal');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Reset translate and opacity
              entry.target.classList.remove('opacity-0', 'translate-y-10', '-translate-x-10', 'translate-x-10', 'scale-95');
              entry.target.classList.add('opacity-100', 'translate-y-0', 'translate-x-0', 'scale-100');
            }
          });
        }, {
          threshold: 0.15,
          rootMargin: "0px 0px -50px 0px"
        });

        reveals.forEach(reveal => {
          observer.observe(reveal);
        });

        // Navigation Highlight Logic
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.nav-link');
        
        const navObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.getAttribute('id');
              navLinks.forEach(link => {
                link.classList.remove('bg-[var(--color-primary)]', 'text-white', 'shadow-md', 'scale-105');
                link.classList.add('text-[var(--color-text-muted)]');
                if (link.getAttribute('href') === `#${id}`) {
                  link.classList.remove('text-[var(--color-text-muted)]');
                  link.classList.add('bg-[var(--color-primary)]', 'text-white', 'shadow-md', 'scale-105');
                }
              });
            }
          });
        }, {
          threshold: 0.2,
          rootMargin: "-20% 0px -40% 0px"
        });

        sections.forEach(sec => navObserver.observe(sec));

        // Anti-gravity cursor effect (subtle parallax)
        const cards = document.querySelectorAll('.hover\\:shadow-\\[0_20px_60px_rgba\\(82\\,140\\,61\\,0\\.4\\)\\]');
        document.addEventListener('mousemove', (e) => {
          const xAxis = (window.innerWidth / 2 - e.pageX) / 50;
          const yAxis = (window.innerHeight / 2 - e.pageY) / 50;
          cards.forEach(card => {
            (card as HTMLElement).style.transform = `rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
          });
        });
      });
    </script>
  </body>
</html>
