---
const programContoh = [
  'Asesmen dan pemetaan potensi serta karakter peserta didik',
  'Program pengembangan gaya belajar',
  'Workshop perencanaan karir dan masa depan',
  'Pelatihan peningkatan kualitas Sumber Daya Manusia',
  'Seminar motivasi dan penguatan karakter',
  'Pendampingan strategi pembinaan individu'
];
---
<section id="portofolio" class="relative py-24 px-8 bg-[var(--color-background)]">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
    <div class="lg:w-1/2 reveal opacity-0 -translate-x-10 transition-all duration-1000 ease-out">
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-bold text-[var(--color-primary)] uppercase tracking-wider mb-8">
        Portofolio Kegiatan
      </h2>
      <p class="text-[var(--color-text-muted)] mb-6 text-lg md:text-2xl leading-relaxed">
        PT. Potensia Mitra Insani memiliki pengalaman penyelenggaraan berbagai program pengembangan individu dan peningkatan kualitas Sumber Daya Manusia melalui kegiatan edukatif, pelatihan dan pendampingan.
      </p>
      <p class="text-[var(--color-text-muted)] mb-12 text-lg md:text-2xl leading-relaxed">
        Program yang kami hadirkan dirancang agar relevan dengan kebutuhan peserta serta memberikan hasil yang dapat langsung diterapkan dalam lingkungan pendidikan maupun organisasi.
      </p>

      <h3 class="text-2xl md:text-3xl font-bold text-[var(--color-primary)] mb-6 uppercase tracking-wide">Contoh Program Yang Dapat Dilaksanakan</h3>
      <ul class="space-y-5">
        {programContoh.map((prog, index) => (
          <li class={`reveal opacity-0 translate-x-10 transition-all duration-700 ease-out flex items-start group`} style={`transition-delay: ${index * 100}ms`}>
            <!-- Star/Polygon Icon -->
            <svg class="w-8 h-8 text-[var(--color-secondary)] mr-4 mt-1 flex-shrink-0 animate-[var(--animate-anti-gravity-slow)]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
            </svg>
            <span class="text-xl md:text-2xl text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">{prog}</span>
          </li>
        ))}
      </ul>
    </div>
    
    <!-- Collage / Floating Images -->
    <div class="lg:w-1/2 relative h-[600px] w-full reveal opacity-0 translate-x-10 transition-all duration-1000 ease-out">
      <!-- Main Photo Placeholder -->
      <div class="absolute top-10 right-10 w-2/3 h-2/3 rounded-xl overflow-hidden shadow-2xl animate-[var(--animate-anti-gravity)] z-20 border-4 border-white">
        <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=800" alt="Pelatihan" class="w-full h-full object-cover" />
      </div>
      <!-- Secondary Photo Placeholder -->
      <div class="absolute bottom-10 left-10 w-3/5 h-2/5 rounded-xl overflow-hidden shadow-xl animate-[var(--animate-anti-gravity-reverse)] z-30 border-4 border-white">
        <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80&w=800" alt="Diskusi" class="w-full h-full object-cover" />
      </div>
      <!-- Background decorative circle -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[var(--color-secondary)] opacity-10 rounded-full blur-3xl -z-10"></div>
    </div>
  </div>
</section>
