---
const programContoh = [
  'Asesmen dan pemetaan potensi serta karakter peserta didik',
  'Program pengembangan gaya belajar',
  'Workshop perencanaan karir dan masa depan',
  'Pelatihan peningkatan kualitas Sumber Daya Manusia',
  'Seminar motivasi dan penguatan karakter',
  'Pendampingan strategi pembinaan individu'
];
---
<section id="portofolio" class="relative py-24 md:py-32 px-6 md:px-12 overflow-hidden">
  <div class="absolute inset-0 bg-[var(--color-background)] -z-20"></div>
  
  <div class="max-w-[1400px] mx-auto flex flex-col lg:flex-row gap-16 items-center">
    <div class="lg:w-1/2 reveal opacity-0 -translate-x-10 transition-all duration-1000 ease-out">
      <p class="text-base md:text-xl uppercase tracking-[0.3em] text-[var(--color-emerald-glow)] mb-4 font-semibold">Portfolio</p>
      <h2 class="reveal-header text-4xl md:text-6xl lg:text-7xl font-extrabold text-[var(--color-text)] uppercase tracking-tight mb-8">
        Portofolio <span class="text-gradient">Kegiatan</span>
      </h2>
      <p class="text-[var(--color-text-muted)] mb-5 text-base md:text-lg leading-relaxed">
        PT. Potensia Mitra Insani memiliki pengalaman penyelenggaraan berbagai program pengembangan individu dan peningkatan kualitas Sumber Daya Manusia melalui kegiatan edukatif, pelatihan dan pendampingan.
      </p>
      <p class="text-[var(--color-text-muted)] mb-10 text-base md:text-lg leading-relaxed">
        Program yang kami hadirkan dirancang agar relevan dengan kebutuhan peserta serta memberikan hasil yang dapat langsung diterapkan dalam lingkungan pendidikan maupun organisasi.
      </p>

      <h3 class="text-xl md:text-2xl font-bold text-[var(--color-text)] mb-6 uppercase tracking-wider">Contoh Program</h3>
      <ul class="space-y-4">
        {programContoh.map((prog, index) => (
          <li class={`reveal opacity-0 translate-x-10 transition-all duration-700 ease-out flex items-start group`} style={`transition-delay: ${index * 100}ms`}>
            <!-- Emerald bullet -->
            <div class="w-2 h-2 rounded-full bg-[var(--color-emerald-glow)] mt-2.5 mr-4 flex-shrink-0 shadow-[0_0_8px_rgba(74,222,128,0.4)] group-hover:shadow-[0_0_16px_rgba(74,222,128,0.7)] transition-shadow duration-300"></div>
            <span class="text-base md:text-lg text-[var(--color-text-muted)] group-hover:text-[var(--color-text)] transition-colors duration-300">{prog}</span>
          </li>
        ))}
      </ul>
    </div>
    
    <!-- Floating Images with Glass Frame -->
    <div class="lg:w-1/2 relative h-[500px] md:h-[600px] w-full reveal opacity-0 translate-x-10 transition-all duration-1000 ease-out">
      <!-- Main Photo -->
      <div class="absolute top-8 right-4 md:right-8 w-[65%] h-[60%] rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.5)] animate-[var(--animate-anti-gravity)] z-20 border border-[var(--color-glass-border)]">
        <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&q=80&w=800" alt="Pelatihan" class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-[rgba(10,15,10,0.5)] to-transparent"></div>
      </div>
      <!-- Secondary Photo -->
      <div class="absolute bottom-8 left-4 md:left-8 w-[55%] h-[38%] rounded-2xl overflow-hidden shadow-[0_15px_40px_rgba(0,0,0,0.4)] animate-[var(--animate-anti-gravity-reverse)] z-30 border border-[var(--color-glass-border)]">
        <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80&w=800" alt="Diskusi" class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-[rgba(10,15,10,0.5)] to-transparent"></div>
      </div>
      <!-- Background glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-[var(--color-emerald-glow)] opacity-[0.04] rounded-full blur-[80px] -z-10"></div>
    </div>
  </div>
  
  <div class="section-glow-line mt-24"></div>
</section>
