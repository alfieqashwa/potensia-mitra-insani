---
---
<!-- Trust Bar: Scrolling Marquee -->
<section class="relative py-12 overflow-hidden">
  <div class="absolute inset-0 bg-[var(--color-background-light)] -z-20"></div>
  <!-- Green overlay tint -->
  <div class="absolute inset-0 bg-gradient-to-r from-[rgba(74,222,128,0.02)] via-transparent to-[rgba(74,222,128,0.02)] -z-10"></div>
  
  <p class="text-center text-xs uppercase tracking-[0.4em] text-[var(--color-text-muted)] mb-8 font-semibold">Dipercaya Oleh</p>
  
  <div class="relative overflow-hidden">
    <!-- Edge fade masks -->
    <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-[var(--color-background-light)] to-transparent z-10"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-[var(--color-background-light)] to-transparent z-10"></div>
    
    <div class="marquee-track">
      {[...Array(2)].map(() => (
        <div class="flex items-center gap-16 px-8">
          <div class="glass-panel !rounded-xl px-8 py-4 flex items-center gap-3 whitespace-nowrap">
            <div class="w-3 h-3 rounded-full bg-[var(--color-emerald-glow)] opacity-60"></div>
            <span class="text-sm font-semibold text-[var(--color-text-muted)]">Institusi Pendidikan</span>
          </div>
          <div class="glass-panel !rounded-xl px-8 py-4 flex items-center gap-3 whitespace-nowrap">
            <div class="w-3 h-3 rounded-full bg-[var(--color-emerald-glow)] opacity-60"></div>
            <span class="text-sm font-semibold text-[var(--color-text-muted)]">Perusahaan Swasta</span>
          </div>
          <div class="glass-panel !rounded-xl px-8 py-4 flex items-center gap-3 whitespace-nowrap">
            <div class="w-3 h-3 rounded-full bg-[var(--color-emerald-glow)] opacity-60"></div>
            <span class="text-sm font-semibold text-[var(--color-text-muted)]">Organisasi Non-Profit</span>
          </div>
          <div class="glass-panel !rounded-xl px-8 py-4 flex items-center gap-3 whitespace-nowrap">
            <div class="w-3 h-3 rounded-full bg-[var(--color-emerald-glow)] opacity-60"></div>
            <span class="text-sm font-semibold text-[var(--color-text-muted)]">Lembaga Pemerintah</span>
          </div>
          <div class="glass-panel !rounded-xl px-8 py-4 flex items-center gap-3 whitespace-nowrap">
            <div class="w-3 h-3 rounded-full bg-[var(--color-emerald-glow)] opacity-60"></div>
            <span class="text-sm font-semibold text-[var(--color-text-muted)]">Yayasan Pendidikan</span>
          </div>
          <div class="glass-panel !rounded-xl px-8 py-4 flex items-center gap-3 whitespace-nowrap">
            <div class="w-3 h-3 rounded-full bg-[var(--color-emerald-glow)] opacity-60"></div>
            <span class="text-sm font-semibold text-[var(--color-text-muted)]">Universitas</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Contact / Footer Section -->
<section id="kontak" class="relative min-h-[80vh] flex items-center justify-center py-24 md:py-32 px-6 md:px-12 overflow-hidden text-center z-10">
  <!-- Dark Emerald Gradient Background -->
  <div class="absolute inset-0 -z-20 bg-gradient-to-b from-[var(--color-background)] via-[#071507] to-[#040d04]"></div>
  
  <!-- Ambient Glows -->
  <div class="absolute inset-0 -z-10 opacity-30 pointer-events-none">
    <div class="absolute top-[-15%] left-[-8%] w-[40vw] h-[40vw] rounded-full bg-[var(--color-secondary)] blur-[120px] opacity-10 animate-[var(--animate-anti-gravity-slow)]"></div>
    <div class="absolute bottom-[-15%] right-[-8%] w-[50vw] h-[50vw] rounded-full bg-[var(--color-emerald-deep)] blur-[100px] opacity-20"></div>
  </div>
  
  <div class="reveal opacity-0 translate-y-10 transition-all duration-1000 ease-out max-w-4xl mx-auto w-full">
    <h2 class="text-4xl md:text-6xl lg:text-8xl font-extrabold uppercase tracking-tight mb-12 md:mb-16 text-[var(--color-text)] animate-[var(--animate-anti-gravity)]">
      Thank <span class="text-gradient">You</span>
    </h2>
    
    <div class="glass-panel p-6 md:p-14 mb-16">
      <p class="font-bold text-lg md:text-2xl text-[var(--color-emerald-glow)] tracking-[0.2em] mb-6 md:mb-10 uppercase">Hubungi Kami</p>
      
      <div class="space-y-2 md:space-y-3 text-base md:text-xl text-[var(--color-text-muted)] tracking-wide mb-10 md:mb-14">
        <p class="font-bold text-xl md:text-3xl mb-4 md:mb-6 text-[var(--color-text)]">PT POTENSIA MITRA INSANI</p>
        <p>Jl. Cendrawasih Komp. Diknas P&amp;K</p>
        <p>Blok A No. 5 RT. 005 / RW. 006</p>
        <p>Cipayung - Ciputat</p>
        <p>Tangerang Selatan</p>
      </div>
      
      <div class="flex flex-col md:flex-row items-stretch md:items-center justify-center gap-4 md:gap-6">
        <!-- WhatsApp Button -->
        <a href="https://wa.me/628179870512" target="_blank" rel="noopener noreferrer" class="magnetic-btn !bg-[#25D366] hover:!bg-[#1ebf5b] gap-3 md:gap-4 text-base md:text-xl hover:shadow-[0_10px_40px_rgba(37,211,102,0.3)] w-full md:w-auto">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5 md:w-7 md:h-7 fill-current">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          0817 987 0512
        </a>
        
        <!-- Email Button -->
        <a href="mailto:potensiamitrainsani@gmail.com" class="magnetic-btn !bg-transparent !border !border-[var(--color-glass-border-hover)] hover:!bg-[rgba(74,222,128,0.08)] !text-[var(--color-emerald-glow)] gap-3 md:gap-4 text-base md:text-xl w-full md:w-auto">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 md:w-7 md:h-7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          Kirim Email
        </a>
      </div>
    </div>
    
    <!-- Minimalist Footer Sitemap -->
    <footer class="mt-16 pt-8 border-t border-[rgba(74,222,128,0.08)]">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <img src="/logo.png" alt="Logo" class="w-8 h-8 object-contain opacity-60" />
          <span class="text-sm text-[var(--color-text-muted)]">PT Potensia Mitra Insani</span>
        </div>
        <nav class="flex flex-wrap justify-center gap-6">
          <a href="#beranda" class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-emerald-glow)] transition-colors duration-300">Home</a>
          <a href="#metodologi" class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-emerald-glow)] transition-colors duration-300">Method</a>
          <a href="#portofolio" class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-emerald-glow)] transition-colors duration-300">Portfolio</a>
          <a href="#komitmen" class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-emerald-glow)] transition-colors duration-300">Mission</a>
          <a href="#tim" class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] hover:text-[var(--color-emerald-glow)] transition-colors duration-300">Team</a>
        </nav>
        <p class="text-xs text-[var(--color-text-muted)] opacity-50">&copy; 2025 Potensia Mitra Insani</p>
      </div>
    </footer>
  </div>
</section>
