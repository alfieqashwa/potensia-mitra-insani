---
---
<section id="beranda" class="relative min-h-screen flex flex-col items-center justify-center p-8 overflow-hidden z-10 pt-24">
  <!-- Abstract Background Elements -->
  <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-gradient-to-br from-[var(--color-secondary)] to-transparent opacity-10 blur-3xl animate-[var(--animate-anti-gravity-slow)] -z-10"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[40vw] h-[40vw] rounded-full bg-gradient-to-tl from-[var(--color-primary)] to-transparent opacity-10 blur-3xl animate-[var(--animate-anti-gravity-reverse)] -z-10"></div>

  <!-- Animated Logo Container -->
  <div class="reveal opacity-0 translate-y-10 transition-all duration-1000 ease-out mb-12 mt-16 md:mt-0 animate-[var(--animate-anti-gravity)] z-20">
    <div class="relative w-64 h-64 md:w-80 md:h-80 flex items-center justify-center bg-transparent rounded-full hover:scale-105 transition-transform duration-500">
      <img src="/logo.png" alt="Logo PT Potensia Mitra Insani" class="w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(30,58,31,0.4)]" />
    </div>
  </div>

  <div class="reveal opacity-0 translate-y-10 transition-all duration-1000 delay-200 ease-out text-center max-w-5xl">
    <h1 class="text-5xl md:text-7xl lg:text-9xl font-bold uppercase tracking-tight text-[var(--color-primary)] mb-8 drop-shadow-sm">
      Potensia Mitra Insani
    </h1>
    <p class="text-lg md:text-2xl lg:text-3xl text-[var(--color-text-muted)] max-w-3xl mx-auto font-medium leading-relaxed">
      Menggali potensi, membangun masa depan dengan pendekatan terukur, aplikatif, dan berkelanjutan.
    </p>
  </div>
</section>
