  <!-- Metrics overlay (hidden until scan completes) -->
  <div class="metrics-overlay" id="metrics-overlay">
    <div class="metric-item metric-item-1">
      <span class="metric-value text-2xl md:text-3xl font-bold text-[var(--color-emerald-glow)]">500+</span>
      <span class="text-xs md:text-sm text-[var(--color-text-muted)] uppercase tracking-widest">Peserta</span>
    </div>
    <div class="metric-item metric-item-2">
      <span class="metric-value text-2xl md:text-3xl font-bold text-[var(--color-emerald-glow)]">50+</span>
      <span class="text-xs md:text-sm text-[var(--color-text-muted)] uppercase tracking-widest">Institusi</span>
    </div>
    <div class="metric-item metric-item-3">
      <span class="metric-value text-2xl md:text-3xl font-bold text-[var(--color-emerald-glow)]">100%</span>
      <span class="text-xs md:text-sm text-[var(--color-text-muted)] uppercase tracking-widest">Terukur</span>
    </div>
  </div>
</div>

<style>
  .fingerprint-container {
    width: 300px;
    height: 380px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
  }

  @media (min-width: 768px) {
    .fingerprint-container {
      width: 380px;
      height: 470px;
    }
  }

  .fingerprint-svg {
    filter: drop-shadow(0 0 30px rgba(74, 222, 128, 0.1));
    color: var(--color-emerald-glow);
  }

  .fingerprint-svg path {
    stroke: var(--color-emerald-glow);
    stroke-width: 1.2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 0 2px rgba(74, 222, 128, 0.2));
    opacity: 0.3;
    transition: opacity 1s ease, filter 1s ease;
  }

  .fingerprint-svg circle {
    transition: opacity 1s ease;
  }

  .fingerprint-svg.scanned path {
    opacity: 0.9;
    filter: drop-shadow(0 0 4px rgba(74, 222, 128, 0.45));
  }

  .fingerprint-svg.scanned circle {
    opacity: 0.45;
  }

  .scan-beam {
    position: absolute;
    top: -10%;
    left: -8%;
    right: -8%;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(74, 222, 128, 0.03) 10%,
      rgba(74, 222, 128, 0.8) 50%,
      rgba(74, 222, 128, 0.03) 90%,
      transparent 100%
    );
    box-shadow:
      0 0 15px rgba(74, 222, 128, 0.35),
      0 0 60px rgba(74, 222, 128, 0.1);
    will-change: transform;
    animation: scanSweep 3.5s ease-in-out infinite;
    pointer-events: none;
    z-index: 10;
  }

  .success-pulse {
    position: absolute;
    inset: -20px;
    border-radius: 12px;
    border: 2px solid transparent;
    pointer-events: none;
    opacity: 0;
  }

  .success-pulse.active {
    animation: pulseSuccess 1.5s ease-out forwards;
  }

  @keyframes scanSweep {
    0% { transform: translateY(0); opacity: 0.4; }
    10% { opacity: 1; }
    50% { transform: translateY(510px); opacity: 1; }
    60% { opacity: 0.4; }
    100% { transform: translateY(0); opacity: 0.4; }
  }

  @keyframes pulseSuccess {
    0% {
      border-color: rgba(74, 222, 128, 0.8);
      transform: scale(0.9);
      opacity: 1;
    }
    100% {
      border-color: rgba(74, 222, 128, 0);
      transform: scale(1.4);
      opacity: 0;
    }
  }

  /* Metrics overlay */
  .metrics-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .metrics-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .metric-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    background: rgba(10, 15, 10, 0.85);
    backdrop-filter: blur(10px);
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    border: 1px solid rgba(74, 222, 128, 0.15);
    transform: translateY(20px);
    opacity: 0;
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .metrics-overlay.visible .metric-item {
    transform: translateY(0);
    opacity: 1;
  }

  .metrics-overlay.visible .metric-item-1 { transition-delay: 0.1s; }
  .metrics-overlay.visible .metric-item-2 { transition-delay: 0.3s; }
  .metrics-overlay.visible .metric-item-3 { transition-delay: 0.5s; }
</style>
