<div class="fingerprint-container" id="fingerprint-hero">
  <!-- Scan Beam -->
  <div class="scan-beam" id="scan-beam"></div>
  
  <!-- Success Pulse Ring -->
  <div class="success-pulse" id="success-pulse"></div>
  
  <!-- SVG Fingerprint matching logo style: dense concentric rounded ridges with central whorl -->

  <svg class="fingerprint-svg" id="fingerprint-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
    <path d="M8.10008 21.221C6.71021 19.2375 5.89258 16.8243 5.89258 14.2187C5.89258 10.8443 8.6265 8.10938 11.9989 8.10938C15.3712 8.10938 18.1051 10.8443 18.1051 14.2187" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M8.10008 21.221C6.71021 19.2375 5.89258 16.8243 5.89258 14.2187C5.89258 10.8443 8.6265 8.10938 11.9989 8.10938C15.3712 8.10938 18.1051 10.8443 18.1051 14.2187" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
