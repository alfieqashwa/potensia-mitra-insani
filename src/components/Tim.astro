---
---
<section id="tim" class="relative py-24 md:py-32 px-6 md:px-12 overflow-hidden">
  <div class="absolute inset-0 bg-[var(--color-background)] -z-20"></div>
  
  <!-- Fingerprint Abstract Background -->
  <div class="absolute bottom-[5%] left-[-12%] w-[500px] h-[500px] text-[var(--color-emerald-glow)] opacity-[0.04] -z-10 animate-[var(--animate-anti-gravity-reverse)] pointer-events-none">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="0.3" stroke="currentColor" class="w-full h-full">
      <g transform="scale(1) translate(0, 0)">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
      </g>
      <g transform="scale(0.8) translate(3, 3)">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
      </g>
      <g transform="scale(1.2) translate(-2, -2)">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
      </g>
      <g transform="scale(1.4) translate(-3.5, -3.5)">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0 1 19.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 0 0 4.5 10.5a7.464 7.464 0 0 1-1.15 3.993m1.989 3.559A11.209 11.209 0 0 0 8.25 10.5a3.75 3.75 0 1 1 7.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 0 1-3.6 9.75m6.633-4.596a18.666 18.666 0 0 1-2.485 5.33"/>
      </g>
    </svg>
  </div>

  <div class="max-w-[1400px] mx-auto flex flex-col-reverse lg:flex-row gap-16 items-center">
    <div class="lg:w-1/2 reveal opacity-0 -translate-x-10 transition-all duration-1000 ease-out">
      <p class="text-base md:text-xl uppercase tracking-[0.3em] text-[var(--color-emerald-glow)] mb-4 font-semibold">Tim</p>
      <h2 class="reveal-header text-4xl md:text-6xl lg:text-7xl font-extrabold text-[var(--color-text)] uppercase tracking-tight mb-8">
        Tim <span class="text-gradient">Kami</span>
      </h2>
      <p class="text-[var(--color-text-muted)] mb-5 text-base md:text-lg leading-relaxed">
        PT. Potensia Mitra Insani didukung oleh tim yang memiliki pengalaman dalam bidang pengembangan Sumber Daya Manusia, pelatihan dan pendampingan individu maupun organisasi.
      </p>
      <p class="text-[var(--color-text-muted)] text-base md:text-lg leading-relaxed">
        Setiap konsultan bekerja dengan menjunjung tinggi profesionalitas, objektifitas, serta komitmen untuk memberikan pelayanan terbaik sesuai kebutuhan mitra kerja.
      </p>
    </div>
    
    <div class="lg:w-1/2 relative flex justify-center lg:justify-end reveal opacity-0 translate-x-10 transition-all duration-1000 ease-out">
      <div class="relative w-[320px] h-[320px] md:w-[420px] md:h-[420px]">
        <!-- Team Image -->
        <div class="absolute inset-0 rounded-full overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.5)] z-10 animate-[var(--animate-anti-gravity-slow)] hover:scale-105 transition-transform duration-500 border-2 border-[var(--color-glass-border)]">
           <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=800" alt="Tim Profesional" class="w-full h-full object-cover" loading="lazy" />
           <div class="absolute inset-0 bg-gradient-to-t from-[rgba(10,15,10,0.4)] to-transparent"></div>
        </div>
        <!-- Glow ring -->
        <div class="absolute inset-[-4px] rounded-full border border-[rgba(74,222,128,0.08)] animate-[var(--animate-anti-gravity)] z-0"></div>
        <!-- Shadow glow -->
        <div class="absolute inset-0 rounded-full bg-[var(--color-emerald-glow)] opacity-[0.04] blur-[60px] translate-y-8 translate-x-6 -z-10 animate-[var(--animate-anti-gravity)]"></div>
      </div>
    </div>
  </div>
  
  <div class="section-glow-line mt-24"></div>
</section>
